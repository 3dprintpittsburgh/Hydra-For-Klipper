# Hydra for Klipper - Printer Configuration
# Add this include to your printer.cfg

[include hydra.cfg]

# NOTE: Remove or comment out any existing [gcode_macro T0] and [gcode_macro T1]
# definitions in your config. Hydra provides its own T0/T1 macros.

# Your START_PRINT should call HYDRA_INIT after homing:
#
# [gcode_macro START_PRINT]
# gcode:
#     G28
#     BED_MESH_CALIBRATE
#     ...
#     HYDRA_INIT TOOL={params.INITIAL_TOOL|default(0)}
